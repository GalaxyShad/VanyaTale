function scr_i18n_init() {
    global.i18n_configs = {
        rus: scr_i18n_rus_original(),
        eng: scr_i18n_eng(),
    };

    scr_i18n_lang_set("eng");
}

function scr_i18n_lang_get() {
    return global.i18n_lang;
}

function scr_i18n_lang_set(lang) {
    global.i18n_lang = lang;

    if (global.i18n_lang == "rus") {
        global.i18n = global.i18n_configs.rus;
    }

    if (global.i18n_lang == "eng") {
        global.i18n = global.i18n_configs.eng;
    }
}

function scr_i18n_lang_switch() {
    scr_i18n_lang_set(global.i18n_lang == "eng" ? "rus" : "eng");
}
